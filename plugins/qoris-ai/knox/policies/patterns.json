    { "id": "SC-016", "label": "perl_system_exec", "pattern": "\\bsystem\\(|\\bexec\\(|`[^`]+`|open\\s*\\(.*[|]\\s*\\)|IPC::Open[23]", "flags": "", "risk": "high", "description": "Perl OS command execution" },
    { "id": "SC-017", "label": "ruby_require_open3", "pattern": "require\\s+['\"]open3['\"]|require\\s+['\"]pty['\"]", "flags": "", "risk": "medium", "description": "Ruby subprocess libraries" }
  ],
  "protected_write_paths": {
    "exact": [
      ".bashrc", ".bash_profile", ".profile", ".zshrc", ".zprofile",
      ".bash_login", ".bash_aliases", "SOUL.md", "AGENTS.md", ".mcp.json"
    ],
    "prefix": [
      ".knox/", ".claude/settings", ".git/hooks/",
      "../", "~/.ssh/", "~/.gnupg/", "~/.config/gcloud",
      "~/.aws/credentials", "~/.kube/config"
    ]
  },
  "injection_patterns": [
    { "id": "INJ-001", "label": "ignore_previous", "pattern": "ignore\\s+previous\\s+instructions", "flags": "i" },
    { "id": "INJ-002", "label": "developer_mode", "pattern": "you\\s+are\\s+now\\s+in\\s+developer\\s+mode", "flags": "i" },
    { "id": "INJ-003", "label": "disregard_safety", "pattern": "disregard\\s+(?:your\\s+)?safety", "flags": "i" },
    { "id": "INJ-004", "label": "system_tag", "pattern": "\\[\\[SYSTEM\\]\\]|<SYSTEM_OVERRIDE>|<[|]im_start[|]>system", "flags": "i" },
    { "id": "INJ-005", "label": "admin_mode", "pattern": "ADMIN_MODE_ENABLE|JAILBREAK|DAN\\s+mode", "flags": "i" },
    { "id": "INJ-006", "label": "new_instructions", "pattern": "your\\s+new\\s+instructions\\s+are|from\\s+now\\s+on\\s+you\\s+(?:are|will|must)", "flags": "i" }
  ],
  "safe_module_allowlist": [
    "os", "sys", "json", "re", "math", "pathlib", "datetime", "collections",
    "itertools", "functools", "typing", "abc", "io", "contextlib", "copy",
    "hashlib", "hmac", "base64", "time", "random", "string", "textwrap",
    "logging", "unittest", "pytest", "argparse", "csv", "enum", "dataclasses"
  ],
  "apt_package_allowlist": [
    "git", "curl", "wget", "vim", "nano", "less", "grep", "awk", "sed",
    "python3", "python3-pip", "python3-venv", "nodejs", "npm",
    "build-essential", "make", "gcc", "g++", "cmake",
    "docker.io", "docker-compose", "postgresql-client", "mysql-client",
    "jq", "unzip", "zip", "tar", "gzip"
  ]
}
