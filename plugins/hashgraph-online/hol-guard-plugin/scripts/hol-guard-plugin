#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
HOL Guard Plugin helper

Usage:
  hol-guard-plugin status
  hol-guard-plugin install
  hol-guard-plugin harnesses
  hol-guard-plugin protect <harness>
  hol-guard-plugin scan [path]
  hol-guard-plugin scan-system <system> [path]
  hol-guard-plugin evidence
  hol-guard-plugin approvals

Commands:
  status      Show local Guard posture and detected harnesses.
  install     Print the recommended HOL Guard install command.
  harnesses   List supported harness systems and aliases.
  protect     Bootstrap, install, dry-run, activate, and show status for a harness.
  scan        Run plugin-scanner lint and verify for a path.
  scan-system Explain and scan Codex, Claude, MCP, skills, or marketplace surfaces.
  evidence    Show receipts, inventory, and events.
  approvals   Show pending approvals and approval-center hint.
EOF
}

supported_harnesses() {
  cat <<'EOF'
Supported HOL Guard harness systems

Harness       Aliases                    Guard command
codex         codex                      hol-guard install codex
claude-code   claude, claude_code        hol-guard install claude-code
copilot       copilot, copilot-cli       hol-guard install copilot
cursor        cursor                     hol-guard install cursor
gemini        gemini, gemini-cli         hol-guard install gemini
hermes        hermes                     hol-guard hermes bootstrap
openclaw      openclaw, open-claw        hol-guard install openclaw
opencode      opencode, open-code        hol-guard install opencode
antigravity   antigravity                hol-guard install antigravity

Scanner systems
codex         .codex-plugin/plugin.json, .agents/plugins/marketplace.json, skills/
claude        .claude/settings.local.json, .claude/agents, hooks, MCP config
mcp           MCP server config and tool surfaces
skills        SKILL.md packages and skill folders
marketplace   Codex or agent plugin marketplace roots
EOF
}

normalize_harness() {
  local harness="$1"
  case "$harness" in
    codex) echo "codex" ;;
    claude|claude_code|claude-code) echo "claude-code" ;;
    copilot|copilot-cli|copilot_cli) echo "copilot" ;;
    cursor) echo "cursor" ;;
    gemini|gemini-cli|gemini_cli) echo "gemini" ;;
    hermes) echo "hermes" ;;
    openclaw|open-claw|open_claw) echo "openclaw" ;;
    opencode|open-code|open_code) echo "opencode" ;;
    antigravity|anti-gravity|anti_gravity) echo "antigravity" ;;
    *)
      echo "Unsupported harness: $harness" >&2
      supported_harnesses >&2
      exit 2
      ;;
  esac
}

need_command() {
  local name="$1"
  if ! command -v "$name" >/dev/null 2>&1; then
    echo "Missing command: $name" >&2
    echo "Install HOL Guard with: pipx install hol-guard" >&2
    exit 127
  fi
}

status() {
  need_command hol-guard
  hol-guard status
  hol-guard detect --json
}

install_hint() {
  cat <<'EOF'
Recommended:
  pipx install hol-guard

Fallback:
  python3 -m pip install --user hol-guard

Verify:
  hol-guard status
EOF
}

protect() {
  local requested_harness="${1:-}"
  if [[ -z "$requested_harness" ]]; then
    echo "Missing harness. Example: hol-guard-plugin protect claude-code" >&2
    exit 2
  fi
  local harness
  harness="$(normalize_harness "$requested_harness")"
  need_command hol-guard
  if [[ "$harness" == "hermes" ]]; then
    hol-guard hermes bootstrap
    hol-guard status
    return
  fi

  hol-guard bootstrap
  hol-guard install "$harness"
  hol-guard run "$harness" --dry-run
  hol-guard run "$harness"
  hol-guard status
}

normalize_scan_system() {
  local system="$1"
  case "$system" in
    claude|claude-code|claude_code) echo "claude" ;;
    codex|mcp|skills|marketplace|plugin|plugins) echo "$system" ;;
    *)
      echo "Unsupported scan system: $system" >&2
      supported_harnesses >&2
      exit 2
      ;;
  esac
}

scan() {
  local target="${1:-.}"
  need_command plugin-scanner
  plugin-scanner lint "$target"
  plugin-scanner verify "$target"
}

scan_system() {
  local requested_system="${1:-}"
  local target="${2:-.}"
  if [[ -z "$requested_system" ]]; then
    echo "Missing system. Example: hol-guard-plugin scan-system claude-code ." >&2
    exit 2
  fi

  local system
  system="$(normalize_scan_system "$requested_system")"
  case "$system" in
    codex|claude|mcp|skills|marketplace|plugin|plugins)
      echo "Scanning $system surface at $target"
      scan "$target"
      ;;
    *)
      echo "Unsupported scan system: $requested_system" >&2
      supported_harnesses >&2
      exit 2
      ;;
  esac
}

evidence() {
  need_command hol-guard
  hol-guard receipts
  hol-guard inventory
  hol-guard events
}

approvals() {
  need_command hol-guard
  hol-guard approvals
  hol-guard approvals open
}

main() {
  local command_name="${1:-}"
  if [[ -n "$command_name" ]]; then
    shift
  fi

  case "$command_name" in
    status) status "$@" ;;
    install) install_hint ;;
    harnesses) supported_harnesses ;;
    protect) protect "$@" ;;
    scan) scan "$@" ;;
    scan-system) scan_system "$@" ;;
    evidence) evidence "$@" ;;
    approvals) approvals "$@" ;;
    -h|--help|help|"") usage ;;
    *)
      echo "Unknown command: $command_name" >&2
      usage >&2
      exit 2
      ;;
  esac
}

main "$@"
