{
  "_comment": "Codex CLI hooks equivalent of hooks.json. Enable hooks in ~/.codex/config.toml: [hooks] enabled = true",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo '🎯 Session Orchestrator v3.6.0 — /session [housekeeping|feature|deep] | /plan [new|feature|retro] | /discovery [scope] | /evolve [analyze|review|list]'",
            "async": false
          },
          {
            "type": "command",
            "command": "node \"$CODEX_PLUGIN_ROOT/hooks/on-session-start.mjs\"",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CODEX_PLUGIN_ROOT/hooks/enforce-scope.mjs\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CODEX_PLUGIN_ROOT/hooks/pre-bash-destructive-guard.mjs\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$CODEX_PLUGIN_ROOT/hooks/enforce-commands.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CODEX_PLUGIN_ROOT/hooks/post-edit-validate.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CODEX_PLUGIN_ROOT/hooks/on-stop.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CODEX_PLUGIN_ROOT/hooks/on-stop.mjs\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$CODEX_PLUGIN_ROOT/hooks/subagent-telemetry.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CODEX_PLUGIN_ROOT/hooks/post-tool-failure-corrective-context.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolBatch": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CODEX_PLUGIN_ROOT/hooks/post-tool-batch-wave-signal.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CODEX_PLUGIN_ROOT/hooks/subagent-telemetry.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CODEX_PLUGIN_ROOT/hooks/cwd-change-restore.mjs\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
